{# ---- Philosophyカード ------------------------------------------
   char : A / K / ² / Lab
   term : 日本語タイトル
   desc : 説明文
   ------------------------------------------------------------ #}
{% macro philosophyCard(char, term, desc) %}
<div class="philosophy-card">
  <span class="philosophy-char">{{ char }}</span>
  <span class="philosophy-term">{{ term }}</span>
  <p class="philosophy-desc">{{ desc }}</p>
</div>
{%- endmacro %}
