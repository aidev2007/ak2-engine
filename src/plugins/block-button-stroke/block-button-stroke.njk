{# ================================================================
   block-button-stroke.njk
   Stroke Draw Button
   ================================================================
   使い方:
     {% from "block-button-stroke/block-button-stroke.njk" import strokeButton %}
     {{ strokeButton("Learn More") }}
     {{ strokeButton("Contact", strokeColor="#6366f1", textColor="#6366f1", radius=24) }}
   ================================================================
   依存: GSAP 3.x（useGsap: true を front-matter に設定するか、
         手動で GSAP を <head> 内に読み込んでください）
   ================================================================ #}

{# ---- Stroke Draw Button -----------------------------------
   text        : ボタンラベル（必須）
   strokeColor : ホバー時ストローク色                         (default: '#111111')
   borderColor : 初期枠線色（省略時は strokeColor の低透明度） (default: '')
   textColor   : テキスト色                                   (default: '#111111')
   fontFamily  : フォントファミリー                           (default: "'DM Sans', sans-serif")
   strokeWidth : 線の太さ px                                  (default: 1.2)
   radius      : 角丸 px                                      (default: 3)
   duration    : ストローク描画時間 秒                        (default: 0.55)
   float       : 浮遊アニメーション on/off                    (default: false)
   ------------------------------------------------------------ #}
{% macro strokeButton(text, strokeColor="#111111", borderColor="", textColor="#111111", fontFamily="'DM Sans', sans-serif", strokeWidth=1.2, radius=3, duration=0.55, float=false) %}
<span class="stroke-btn-host"
  data-stroke-btn
  data-text="{{ text | escape }}"
  data-stroke-color="{{ strokeColor }}"
  data-border-color="{{ borderColor }}"
  data-text-color="{{ textColor }}"
  data-font-family="{{ fontFamily | escape }}"
  data-stroke-width="{{ strokeWidth }}"
  data-radius="{{ radius }}"
  data-duration="{{ duration }}"
  data-float="{{ 'true' if float else 'false' }}"></span>
{%- endmacro %}
