{# ================================================================
   effect-bg-sakura.njk
   桜吹雪セクション背景エフェクト
   ================================================================
   使い方:
     {% from "effect-bg-sakura/effect-bg-sakura.njk" import bgSakura %}
     {{ bgSakura() }}

   前提条件:
     - 親セクションに position: relative を設定
     - utils: [section-effects] で section-effects.js をロード
   ================================================================ #}

{# ---- 桜吹雪 背景エフェクト canvas --------------------------------
   section の position:relative の中に置くこと
   section-effects.js が自動検出してエフェクトを描画する
   ------------------------------------------------------------ #}
{% macro bgSakura() %}
<canvas class="section-bg-canvas" data-section-effect="SakuraEffect" aria-hidden="true"></canvas>
{%- endmacro %}
