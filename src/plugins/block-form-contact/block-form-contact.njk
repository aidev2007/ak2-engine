{# ================================================================
   block-form-contact.njk
   コンタクトフォーム
   ================================================================
   使い方:
     {% from "block-form-contact/block-form-contact.njk" import contactForm %}
     intro あり:
     {% call contactForm() %}...{% endcall %}
     intro なし:
     {{ contactForm() }}
   ================================================================ #}

{# ---- コンタクトフォーム ----------------------------------------
   action : form の action 属性（省略可）
   introテキストは caller() で渡す（省略可）
   ------------------------------------------------------------ #}
{% macro contactForm(action="") %}
{% if caller %}
<div class="contact-intro">
  {{ caller() }}
</div>
{% endif %}
<div class="contact-form">
  <form{% if action %} action="{{ action }}"{% endif %}>
    <div class="form-group">
      <label class="form-label" for="contact-name">お名前</label>
      <input id="contact-name" type="text" class="form-input" placeholder="例：山田 太郎" autocomplete="name">
    </div>
    <div class="form-group">
      <label class="form-label" for="contact-email">メールアドレス</label>
      <input id="contact-email" type="email" class="form-input" placeholder="例：email@example.com" autocomplete="email">
    </div>
    <div class="form-group">
      <label class="form-label" for="contact-message">お問い合わせ内容</label>
      <textarea id="contact-message" class="form-textarea" placeholder="ご相談内容をご記入ください"></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-base btn-primary contact-submit">送信する</button>
    </div>
  </form>
</div>
{%- endmacro %}
